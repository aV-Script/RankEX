# ── RankEX — variabili E2E test ───────────────────────────────────────────────
# Copia in .env.test e compila con gli account del progetto rankex-dev.
# NON committare questo file con valori reali.

# URL base del dev server (default: http://localhost:5173)
PLAYWRIGHT_BASE_URL=http://localhost:5173
PLAYWRIGHT_ADMIN_URL=http://localhost:5174

# ── Account di test (devono esistere nel progetto rankex-dev) ─────────────────

E2E_TRAINER_EMAIL=trainer@test.rankex
E2E_TRAINER_PASSWORD=TrainerTest1

E2E_ORGADMIN_EMAIL=orgadmin@test.rankex
E2E_ORGADMIN_PASSWORD=OrgAdminTest1

E2E_CLIENT_EMAIL=client@test.rankex
E2E_CLIENT_PASSWORD=ClientTest1

E2E_STAFF_EMAIL=staff@test.rankex
E2E_STAFF_PASSWORD=StaffTest1

E2E_SUPERADMIN_EMAIL=admin@test.rankex
E2E_SUPERADMIN_PASSWORD=SuperAdminTest1

# ── Org IDs di test (creati in global-setup o già esistenti in rankex-dev) ────

E2E_ORG_PT=test-org-pt
E2E_ORG_SOCCER=test-org-soccer

# ── Firebase Emulator (lasciare vuoto per usare rankex-dev) ──────────────────
# VITE_FIREBASE_EMULATOR_HOST=localhost
# VITE_FIRESTORE_EMULATOR_PORT=8080
# VITE_AUTH_EMULATOR_PORT=9099

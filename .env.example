# ──────────────────────────────────────────────────────────────
# RankEX — variabili d'ambiente
#
# Copia questo file in .env.development (per dev locale)
# o .env.production (per build prod).
# NON committare mai file .env con credenziali reali.
# ──────────────────────────────────────────────────────────────

# Ambiente corrente: development | uat | production
VITE_ENV=

# ── Firebase ──────────────────────────────────────────────────
# Trovate in Firebase Console → Impostazioni progetto → App Web

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ──────────────────────────────────────────────────────────────
# RankEX — variabili d'ambiente
#
# Copia questo file in .env.development (per dev locale)
# o .env.production (per build prod).
# NON committare mai file .env con credenziali reali.
# ──────────────────────────────────────────────────────────────

# Ambiente corrente: development | uat | production
VITE_ENV=

# ── Firebase ──────────────────────────────────────────────────
# Trovate in Firebase Console → Impostazioni progetto → App Web

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── App Check (reCAPTCHA v3) ──────────────────────────────────
# 1. Crea il sito su https://www.google.com/recaptcha/admin/create
#    Tipo: reCAPTCHA v3 — aggiungi i domini: rankex-app.web.app, rankex-admin.web.app, localhost
# 2. Registra l'app in Firebase Console → App Check → App Web → reCAPTCHA v3
# 3. Copia qui la "Chiave del sito" (non la chiave segreta)
VITE_RECAPTCHA_SITE_KEY=

# ──────────────────────────────────────────────────────────────
# Rank EX— variabili d'ambiente
# Copia questo file in .env e inserisci i tuoi valori Firebase.
# NON committare mai il file .env su Git.
# ──────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────
# Trovate in Firebase Console → Impostazioni progetto → App Web

# Chiave API pubblica del progetto Firebase
VITE_FIREBASE_API_KEY=

# Dominio usato per l'autenticazione (es. myapp.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=

# ID del progetto Firebase
VITE_FIREBASE_PROJECT_ID=

# Bucket per Firebase Storage (es. myapp.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=

# ID mittente per Firebase Cloud Messaging
VITE_FIREBASE_MESSAGING_SENDER_ID=

# ID univoco dell'app Firebase
VITE_FIREBASE_APP_ID=

# ID misurazione Google Analytics (opzionale)
VITE_FIREBASE_MEASUREMENT_ID=
